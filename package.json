{
  "name": "tmax",
  "version": "0.2.0",
  "description": "Extensible terminal-based text editor with T-Lisp (Alpha)",
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/main.tsx",
    "dev": "node --watch --import tsx src/main.tsx --dev",
    "tui": "bun src/client/tui-client.ts",
    "daemon": "bun src/server/server.ts",
    "tlisp": "bun src/tlisp/cli.ts",
    "repl": "bun src/tlisp/cli.ts",
    "test": "bun test --timeout 30000",
    "test:unit": "bun test --timeout 30000 test/unit/",
    "test:integration": "bun test --timeout 30000 test/integration/",
    "test:daemon": "cd test/ui && uv run python run_python_suite.py daemon",
    "test:ui": "cd test/ui && uv run python run_python_suite.py",
    "test:ui:renderer": "cd test/ui && uv run python run_python_suite.py daemon-tmux",
    "test:ui:helpers": "cd test/ui && uv run python tests/test_harness_helpers.py",
    "tmux:audit": "bash scripts/tmax-tmux-audit.sh",
    "tmux:cleanup-stale": "bash scripts/tmax-tmux-audit.sh --cleanup-stale-shells",
    "check": "node --import tsx --eval \"import('./src/main.tsx')\" -- --help",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:src": "bunx tsc --noEmit --project tsconfig.src.json",
    "typecheck:test": "bunx tsc --noEmit --project tsconfig.test.json",
    "build": "bun run build:tmax && bun run build:tlisp",
    "build:tmax": "bun build --compile ./src/main.tsx --outfile dist/tmax",
    "build:tlisp": "bun build --compile ./src/tlisp/cli.ts --outfile dist/tlisp"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "react": "^18.3.1",
    "typescript": "^5.9.3",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/bun": "latest"
  },
  "browser": {
    "fs": false,
    "path": false
  },
  "bin": {
    "tmax": "./bin/tmax",
    "tlisp": "./bin/tlisp"
  }
}
