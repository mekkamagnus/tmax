{
  "name": "tmax",
  "version": "0.2.0",
  "description": "Extensible terminal-based text editor with T-Lisp (Alpha)",
  "type": "module",
  "scripts": {
    "start": "bun src/main.ts",
    "dev": "bun --watch src/main.ts --dev",
    "tui": "bun src/client/tui-client.ts",
    "daemon": "bun src/server/server.ts",
    "tlisp": "bun src/tlisp/cli.ts",
    "repl": "bun src/tlisp/cli.ts",
    "test": "bun test --timeout 30000",
    "test:unit": "bun scripts/run-unit-tests.ts",
    "test:adw": "bun test --timeout 30000 test/unit/adw-*.test.ts",
    "test:integration": "bun test --timeout 30000 test/integration/",
    "test:tmax-use": "bin/tmax-use test",
    "tmux:audit": "bash scripts/tmax-tmux-audit.sh",
    "tmux:cleanup-stale": "bash scripts/tmax-tmux-audit.sh --cleanup-stale-shells",
    "check": "bun src/main.ts --help",
    "typecheck": "bun run typecheck:src && bun run typecheck:test && bun run typecheck:tmax-use && bun run typecheck:bench",
    "typecheck:src": "bunx tsc --noEmit --project tsconfig.src.json",
    "typecheck:test": "bunx tsc --noEmit --project tsconfig.test.json",
    "typecheck:tmax-use": "bunx tsc --noEmit --project tsconfig.tmax-use.json",
    "typecheck:bench": "bunx tsc --noEmit --project tsconfig.bench.json",
    "bench": "bun run bench/bench.ts",
    "bench:all": "bun run bench/bench.ts all",
    "build": "bun run build:tmax && bun run build:tlisp && bun run build:tmax-use",
    "build:tmax": "bun build --compile ./src/main.ts --outfile dist/tmax",
    "build:tlisp": "bun build --compile ./src/tlisp/cli.ts --outfile dist/tlisp",
    "build:tmax-use": "bun build --compile ./tmax-use/test/cli.ts --outfile dist/tmax-use",
    "test:trt": "bin/trt",
    "adw": "bun adws/adw-launch.ts",
    "adw:resume": "bun adws/adw-launch.ts --resume"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "typescript": "^5.9.3"
  },
  "browser": {
    "fs": false,
    "path": false
  },
  "bin": {
    "tmax": "./bin/tmax",
    "tlisp": "./bin/tlisp",
    "trt": "./bin/trt",
    "tmax-use": "./bin/tmax-use"
  }
}
