(defmodule editor/commands/operators
  (export vim-operator-pending-p vim-begin-operator vim-reset-operator vim-operator-total-count vim-delete-line-range vim-delete-to-last-line vim-delete-to-first-line vim-change-line-range vim-operator-apply vim-dispatch-operator-key vim-operator-find-pending-p vim-operator-reset-find-pending vim-operator-apply-find)

;; operators.tlisp -- Vim operator-pending state owned by T-Lisp

(defvar vim-pending-operator nil)
(defvar vim-operator-count 1)
(defvar vim-operator-g-pending nil)

;; Stashed operator state for operator+find-char combos (df/dt/dF/dT + y/c).
;; Populated by vim-dispatch-operator-key when f/t/F/T arrives while an
;; operator is pending. Consumed by vim-operator-apply-find after the find
;; target resolves.
(defvar vim-pending-operator-for-find nil)
(defvar vim-pending-operator-for-find-count 1)

(defun vim-operator-pending-p ()
  "Return t when an operator is waiting for a motion."
  (not (null vim-pending-operator)))

(defun vim-begin-operator (operator)
  "Begin a Vim OPERATOR command."
  (progn
    (set! vim-pending-operator operator)
    (set! vim-operator-count (vim-count-consume))
    (editor-set-status (concat operator " operator"))
    t))

(defun vim-reset-operator ()
  "Clear pending operator state."
  (progn
    (set! vim-pending-operator nil)
    (set! vim-operator-count 1)
    (set! vim-operator-g-pending nil)
    (set! vim-pending-operator-for-find nil)
    (set! vim-pending-operator-for-find-count 1)
    nil))

(defun vim-operator-find-pending-p ()
  "Return t when a find-char motion is being collected for a stashed operator."
  (not (null vim-pending-operator-for-find)))

(defun vim-operator-reset-find-pending ()
  "Clear stashed operator-for-find state."
  (progn
    (set! vim-pending-operator-for-find nil)
    (set! vim-pending-operator-for-find-count 1)
    nil))

(defun vim-operator-find-combo (operator direction till-p)
  "Build the combo string for undo history (e.g., df, dt, dF, dT)."
  (let ((suffix
    (cond
      ((and (string= direction "forward") (not till-p)) "f")
      ((and (string= direction "forward") till-p) "t")
      ((and (string= direction "backward") (not till-p)) "F")
      ((and (string= direction "backward") till-p) "T"))))
    (concat operator suffix)))

(defun vim-operator-begin-find (key)
  "Stash the pending operator and enter find-char pending state for KEY.
KEY must be one of f/t/F/T. The operator and its pre-operator count are
preserved in vim-pending-operator-for-find* so vim-operator-apply-find
can resume after the find target resolves. vim-reset-operator clears the
stash, so it must run BEFORE the stash is populated."
  (let ((operator vim-pending-operator))
    (let ((operator-count vim-operator-count))
      (let ((forward (or (string= key "f") (string= key "t"))))
        (let ((till (or (string= key "t") (string= key "T"))))
          (progn
            (vim-reset-operator)
            (set! vim-pending-operator-for-find operator)
            (set! vim-pending-operator-for-find-count operator-count)
            (vim-begin-find (if forward "forward" "backward") till)
            t))))))

(defun vim-operator-apply-find (char direction till-p motion-count)
  "Apply the stashed operator to a find-char motion.
CHAR is the find target, DIRECTION/TILL-P describe the find variant,
and MOTION-COUNT is the count accumulated between operator and find
char (already consumed). The stashed operator count multiplies it."
  (let ((operator vim-pending-operator-for-find))
    (let ((operator-count vim-pending-operator-for-find-count))
      (let ((total-count (* operator-count motion-count)))
        (let ((line (cursor-line)))
          (let ((start-col (cursor-column)))
            (let ((position (find-char-position char direction till-p total-count)))
              (progn
                (vim-operator-reset-find-pending)
                (vim-count-reset)
                (if (null position)
                  (progn
                    (editor-set-status (concat "Char not found: " char))
                    t)
                  (let ((target-col (nth 1 position)))
                    (let ((low (min start-col target-col)))
                      (let ((high (+ (max start-col target-col) 1)))
                        (let ((combo (vim-operator-find-combo operator direction till-p)))
                          (progn
                            (if (string= operator "y") nil (undo-begin))
                            (cond
                              ((string= operator "d")
                                (let ((deleted (buffer-delete-range line low line high)))
                                  (set-register "\"" deleted)))
                              ((string= operator "y")
                                (let ((text (buffer-get-range line low line high)))
                                  (set-register "\"" text)))
                              ((string= operator "c")
                                (progn
                                  (buffer-replace-range line low line high "")
                                  (cursor-move line low)
                                  (editor-set-mode "insert")))
                              (t (editor-set-status (concat "Unsupported operator: " combo))))
                            (if (string= operator "y") nil (undo-commit combo))
                            t))))))))))))))

(defun vim-operator-total-count ()
  "Return operator prefix count multiplied by motion count."
  (* vim-operator-count (vim-count-current)))

(defun vim-delete-line-range (start-line end-line)
  "Delete full lines from START-LINE through END-LINE."
  (let ((line-count (buffer-line-count)))
    (let ((start (min start-line end-line)))
      (let ((end (max start-line end-line)))
        (let ((exclusive-end (min (+ end 1) line-count)))
          (if (>= exclusive-end line-count)
            (if (> start 0)
              (let ((previous-line (- start 1)))
                (let ((previous-length (length (buffer-line previous-line))))
                  (let ((deleted
                    (buffer-delete-range
                      previous-line
                      previous-length
                      (- line-count 1)
                      (length (buffer-line (- line-count 1))))))
                    (progn
                      (set-register "\"" (concat (substring deleted 1 (length deleted)) "\n"))
                      (cursor-move previous-line 0)
                      deleted))))
              (let ((deleted
                (buffer-delete-range start 0 (- line-count 1) (length (buffer-line (- line-count 1))))))
                (progn
                  (set-register "\"" (concat deleted "\n"))
                  deleted)))
            (let ((deleted (buffer-delete-range start 0 exclusive-end 0)))
              (progn
                (set-register "\"" deleted)
                deleted))))))))

(defun vim-delete-to-last-line ()
  "Delete from current line through the final line."
  (progn
    (vim-delete-line-range (cursor-line) (- (buffer-line-count) 1))
    t))

(defun vim-delete-to-first-line ()
  "Delete from the first line through current line."
  (progn
    (vim-delete-line-range 0 (cursor-line))
    t))

(defun vim-change-line-range (count)
  "Change COUNT full lines, leaving one empty line in insert mode."
  (let ((start (cursor-line)))
    (let ((line-count (buffer-line-count)))
      (let ((exclusive-end (min (+ start count) line-count)))
        (let ((ends-before-eof (< exclusive-end line-count)))
          (let ((end-line (if ends-before-eof exclusive-end (- line-count 1))))
            (let ((end-column (if ends-before-eof 0 (length (buffer-line end-line)))))
              (let ((deleted (buffer-get-range start 0 end-line end-column)))
                (progn
                  (set-register "\"" (if ends-before-eof deleted (concat deleted "\n")))
                  (buffer-replace-range start 0 end-line end-column (if ends-before-eof "\n" ""))
                  (cursor-move start 0)
                  (editor-set-mode "insert")
                  t)))))))))

(defun vim-operator-apply (motion)
  "Apply pending operator to MOTION."
  (let ((operator vim-pending-operator))
    (let ((count (vim-operator-total-count)))
      (let ((combo (concat operator motion)))
        (progn
          (vim-reset-operator)
          (vim-count-reset)
          (if (string= operator "y") nil (undo-begin))
          (cond
            ((string= combo "dd") (vim-delete-line-range (cursor-line) (+ (cursor-line) (- count 1))))
            ((string= combo "dw") (delete-word count))
            ((string= combo "dl") (vim-delete-char count))
            ((string= combo "d$") (delete-to-line-end))
            ((string= combo "dG") (vim-delete-to-last-line))
            ((string= combo "dgg") (vim-delete-to-first-line))
            ((string= combo "yy") (yank-line count))
            ((string= combo "yw") (yank-word count))
            ((string= combo "yl") (yank-chars count))
            ((string= combo "y$") (yank-to-line-end))
            ((string= combo "cc") (vim-change-line-range count))
            ((string= combo "cw") (change-word count))
            ((string= combo "cl") (vim-change-char count))
            ((string= combo "c$") (change-to-line-end))
            (t (editor-set-status (concat "Unsupported operator: " combo))))
          (if (string= operator "y") nil (undo-commit combo))
          t)))))

(defun vim-dispatch-operator-key (key)
  "Dispatch KEY while an operator is pending."
  (if vim-operator-g-pending
    (progn
      (set! vim-operator-g-pending nil)
      (if (string= key "g")
        (vim-operator-apply "gg")
        (progn
          (vim-reset-operator)
          (vim-count-reset)
          (editor-set-status (concat "Unsupported operator prefix: g" key))
          t)))
    (let ((digit (vim-key-digit-value key)))
      (if (numberp digit)
        (progn
          (vim-count-add-digit digit)
          t)
        (if (string= key "g")
          (progn
            (set! vim-operator-g-pending t)
            t)
          (if (or (string= key "f") (string= key "t") (string= key "F") (string= key "T"))
            (vim-operator-begin-find key)
            (vim-operator-apply key)))))))
)
