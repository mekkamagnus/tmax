#!/usr/bin/env bash
# trt — T-Lisp Runtime Testing runner (SPEC-049).
# Thin wrapper delegating to `tmax --test` so the test runtime == the user runtime (the daemon).
# Routes every test category — pure logic AND editor-touching — through one runner.
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH")"
fi

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

exec "$PROJECT_DIR/bin/tmax" --test "$@"
