    markdown-toggle-code markdown-toggle-delimiter markdown-toggle-code-block
    markdown-promote-heading markdown-demote-heading markdown-insert-heading
    markdown-align-table pad-right markdown-insert-list-item markdown-renumber-list
    markdown-shell-quote markdown-follow-link markdown-insert-link
    markdown-jump-back markdown-link-at-point
    markdown-skip-front-matter markdown-generate-toc
    markdown-do markdown-toggle-checkbox markdown-preview
    markdown-list-continue
    markdown-kill-subtree markdown-copy-subtree
    markdown-move-subtree-up markdown-move-subtree-down
    markdown-promote-subtree markdown-demote-subtree
    markdown-sparse-tree-regex markdown-sparse-tree-level
