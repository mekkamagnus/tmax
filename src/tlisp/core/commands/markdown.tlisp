    markdown-wiki-link-at-point markdown-scan-tags markdown-next-wiki-link markdown-prev-wiki-link markdown-scan-wiki-links
    markdown-current-subtree-range markdown-find-sibling-ranges
    markdown-inline-to-html markdown-table-to-latex markdown-find-unlinked-mentions markdown-dirname markdown-embed-target-at-point markdown-follow-embed)

;; markdown.tlisp — CHORE-44 Change 11 loader/aggregator.
;;
;; The 96 public markdown-* functions now live in seven feature modules under
;; commands/markdown/. This file loads every feature module once and re-provides
;; the "markdown-commands" feature so existing callers (normal.tlisp requires
;; `editor/commands/markdown`; markdown-mode.tlisp binds keys to `markdown-*`
;; command strings evaluated from globalEnv) keep working unchanged.
;;
;; Unqualified `markdown-*` calls resolve at evaluation time via the
;; evaluator's unique-export fallback (module-registry.resolveUniqueExport):
;; each public function is exported by EXACTLY ONE feature module, so the
;; unqualified name always lands in the right place.
;;
;; AC11.2: this aggregator contains NO feature defun. Add new markdown-*
;; functions to the appropriate feature module, not here.

(require-module editor/commands/markdown/navigation)
(require-module editor/commands/markdown/formatting)
(require-module editor/commands/markdown/tables)
(require-module editor/commands/markdown/links)
(require-module editor/commands/markdown/execution)
(require-module editor/commands/markdown/export)
(require-module editor/commands/markdown/knowledge)

(provide "markdown-commands")
)
