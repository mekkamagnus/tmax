#!/usr/bin/env bun
/**
 * @file tmaxclient
 * @description Client CLI tool for connecting to tmax server
 * Implements JSON-RPC 2.0 protocol for communication with server
 */

import { Socket } from 'net';
import { userInfo } from 'os';
import { spawnSync } from 'child_process';

// JSON-RPC 2.0 interfaces
interface JSONRPCRequest {
  jsonrpc: '2.0';
  id: string | number;
  method: string;
  params?: any;
}

interface JSONRPCResponse {
  jsonrpc: '2.0';
  id: string | number;
  result?: any;
  error?: {
    code: number;
    message: string;
    data?: any;
  };
}

class TmaxClient {
  private socketPath: string;
  private connection: Socket | null = null;

  constructor(socketPath?: string) {
    this.socketPath = socketPath || this.getDefaultSocketPath();
  }

  /**
   * Get the default socket path
   */
  private getDefaultSocketPath(): string {
    if (process.env.TMAX_SOCKET) return process.env.TMAX_SOCKET;
    const uid = process.env.SUDO_UID || userInfo().uid.toString();
    return `/tmp/tmax-${uid}/server`;
  }

  /**
   * Connect to the server
   */
  async connect(): Promise<void> {
    return new Promise((resolve, reject) => {
      this.connection = new Socket();

      this.connection.connect(this.socketPath, () => {
        resolve();
      });

      this.connection.on('error', (err) => {
        reject(err);
      });
    });
  }

  /**
   * Send a request to the server
   */
  async sendRequest(method: string, params: any): Promise<any> {
    if (!this.connection) {
      throw new Error('Not connected to server');
    }

    const requestId = Date.now();
    const request: JSONRPCRequest = {
      jsonrpc: '2.0',
      id: requestId,
      method,
      params
    };

    return new Promise((resolve, reject) => {
      let buffer = '';
      const responseHandler = (data: Buffer) => {
        try {
          buffer += data.toString();
          const responses = this.parseMultipleResponses(buffer);

          for (const response of responses) {
            if (response.id === requestId) {
              this.connection?.removeListener('data', responseHandler);

              if (response.error) {
                reject(new Error(`${response.error.code}: ${response.error.message}`));
              } else {
                resolve(response.result);
              }
              return;
            }
          }
        } catch (error) {
          this.connection?.removeListener('data', responseHandler);
          reject(error);
        }
      };

      this.connection.on('data', responseHandler);

      // Send request
      this.connection.write(JSON.stringify(request) + '\n');
    });
  }

  /**
   * Parse multiple JSON-RPC responses from a single data chunk
   */
  private parseMultipleResponses(data: string): JSONRPCResponse[] {
    const responses: JSONRPCResponse[] = [];
    let startPos = 0;
    let braceCount = 0;
    let inString = false;
    let escapeNext = false;

    for (let i = 0; i < data.length; i++) {
      const char = data[i];

      if (escapeNext) {
        escapeNext = false;
        continue;
      }

      if (char === '\\' && inString) {
        escapeNext = true;
        continue;
      }

      if (char === '"') {
        inString = !inString;
        continue;
      }

      if (!inString) {
        if (char === '{') {
          if (braceCount === 0) {
            startPos = i;
          }
          braceCount++;
        } else if (char === '}') {
          braceCount--;
          if (braceCount === 0) {
            try {
              const responseStr = data.substring(startPos, i + 1);
              const response = JSON.parse(responseStr.trim());
              if (response && typeof response === 'object') {
                responses.push(response);
              }
            } catch (e) {
              console.error('Error parsing JSON response:', e);
            }
          }
        }
      }
    }

    return responses;
  }

  /**
   * Open a file in the server
   */
  async openFile(filepath: string, options?: { wait?: boolean }): Promise<void> {
    const wait = options?.wait ?? true;

    try {
      await this.sendRequest('open', {
        filepath,
        wait
      });

      if (wait) {
        // For now, just return after sending the request
        // In a real implementation, we'd wait for the buffer to be closed
        return;
      }
    } catch (error) {
      console.error(`Error opening file ${filepath}:`, error);
      process.exit(1);
    }
  }

  /**
   * Evaluate T-Lisp code
   */
  async eval(code: string): Promise<any> {
    try {
      return await this.sendRequest('eval', { code });
    } catch (error) {
      console.error(`Error evaluating code:`, error);
      process.exit(1);
    }
  }

  /**
   * Execute a command
   */
  async executeCommand(command: string, params?: any): Promise<any> {
    try {
      return await this.sendRequest('command', { command, ...params });
    } catch (error) {
      console.error(`Error executing command ${command}:`, error);
      process.exit(1);
    }
  }

  /**
   * Query server state
   */
  async query(query: string, params?: any): Promise<any> {
    try {
      return await this.sendRequest('query', { query, ...params });
    } catch (error) {
      console.error(`Error querying server:`, error);
      process.exit(1);
    }
  }

  /**
   * Ping the server
   */
  async ping(): Promise<boolean> {
    try {
      const result = await this.sendRequest('ping', {});
      // Just output the status without extra info for clean exit code handling
      return true;
    } catch (error) {
      return false;
    }
  }

  /**
   * Close the connection
   */
  close(): void {
    if (this.connection) {
      this.connection.destroy();
      this.connection = null;
    }
  }
}

/**
 * Parse a key sequence string into individual key strings.
 * Supports <Escape>, <Enter>, <Space>, <Tab>, <Backspace>, and single characters.
 */
function parseKeySequence(sequence: string): string[] {
  const keys: string[] = [];
  let i = 0;
  while (i < sequence.length) {
    if (sequence[i] === '<') {
      const end = sequence.indexOf('>', i);
      if (end !== -1) {
        const keyName = sequence.substring(i + 1, end);
        const keyMap: Record<string, string> = {
          'Escape': '\x1b',
          'Enter': '\r',
          'Space': ' ',
          'Tab': '\t',
          'Backspace': '\x7f',
          'SPC': ' ',
          'RET': '\r',
          'ESC': '\x1b',
          'TAB': '\t',
          'BS': '\x7f',
          'DEL': '\x7f',
        };
        keys.push(keyMap[keyName] ?? keyName);
        i = end + 1;
        continue;
      }
    }
    keys.push(sequence[i]!);
    i++;
  }
  return keys;
}

/**
 * Main function to handle command line arguments
 */
async function main(): Promise<void> {
  const args = process.argv.slice(2);

  // Show help if requested
  if (args.includes('--help') || args.includes('-h')) {
    console.log(`
tmaxclient - Client for tmax server

Usage: tmaxclient [options] [filename]

Options:
  --tui                  Launch TUI client (full terminal editor)
  --eval CODE            Evaluate T-Lisp code
  --key KEY              Send a keypress to the active frame
  --keys SEQUENCE        Replay a key sequence on the active frame
  --command NAME         Execute an editor command by name
  --diagnostics          List recent T-Lisp diagnostics
  --since-request ID     Filter diagnostics to a specific request ID
  --last-error           Show the last T-Lisp error with full diagnostic
  --backtrace            Show the T-Lisp backtrace from the last error
  --list-buffers         List all buffers
  --kill-buffer NAME     Kill specific buffer
  --insert TEXT          Insert text at cursor
  --insert-stdin         Insert from stdin
  --script FILE          Execute T-Lisp file
  --server-info          Get server info
  --status               Get daemon/client/frame status
  --clients              List connected clients
  --frames               List connected frames
  --frame FRAME_ID       Target a specific frame for key/command operations
  --json                 Print raw JSON for status-like commands
  --messages             Show *Messages* buffer
  --ping                 Check if server running
  --stop                 Stop the running daemon
  -n, --no-wait         Don't wait for buffer to close
  -c                     Open in new frame/buffer (not implemented yet)
  -nw                   No window mode (not implemented yet, for $EDITOR)
  -s, --socket PATH     Custom socket path
  -h, --help            Show this help message

Examples:
  tmaxclient file.txt           # Open file.txt
  tmaxclient --eval '(buffer-list)'  # Evaluate T-Lisp
  tmaxclient --key i            # Send 'i' key to active frame (enter insert)
  tmaxclient --keys 'i hello<Escape>'  # Replay key sequence
  tmaxclient --command save-buffer    # Run M-x command
  tmaxclient --diagnostics --json     # List diagnostics as JSON
  tmaxclient --last-error             # Show last error with code/span/help
  tmaxclient --kill-buffer scratch.tlisp  # Kill specific buffer
  tmaxclient -n file.txt        # Open file without waiting
  tmaxclient -s /tmp/my-socket file.txt  # Use custom socket
  echo 'TODO' | tmaxclient --insert-stdin  # Insert from stdin
  tmaxclient --ping             # Check if server running
    `);
    process.exit(0);
  }

  // Parse arguments
  let socketPath: string | undefined;
  let noWait = args.includes('-n') || args.includes('--no-wait');
  let newFrame = args.includes('-c');  // Open in new frame/buffer
  let noWindow = args.includes('-nw'); // No window mode (for $EDITOR compatibility)
  let evalCode: string | undefined;
  let listBuffers = args.includes('--list-buffers');
  let killBuffer: string | undefined;
  let insertText: string | undefined;
  let scriptFile: string | undefined;
  let serverInfo = args.includes('--server-info');
  let status = args.includes('--status');
  let clients = args.includes('--clients');
  let frames = args.includes('--frames');
  let jsonOutput = args.includes('--json');
  let showMessages = args.includes('--messages');
  let ping = args.includes('--ping');
  let stopDaemon = args.includes('--stop');
  let insertStdin = args.includes('--insert-stdin');
  let tuiMode = args.includes('--tui');
  let showDiagnostics = args.includes('--diagnostics');
  let showLastError = args.includes('--last-error');
  let showBacktrace = args.includes('--backtrace');
  let keyArg: string | undefined;
  let keysArg: string | undefined;
  let commandArg: string | undefined;
  let frameTarget: string | undefined;
  let sinceRequestId: string | number | undefined;

  // Parse socket path
  const socketIndex = args.indexOf('-s');
  if (socketIndex !== -1) {
    socketPath = args[socketIndex + 1];
  }

  const socketArgIndex = args.indexOf('--socket');
  if (socketArgIndex !== -1) {
    socketPath = args[socketArgIndex + 1];
  }

  // Parse eval code
  const evalIndex = args.indexOf('--eval');
  if (evalIndex !== -1) {
    evalCode = args[evalIndex + 1];
  }

  // Parse kill buffer
  const killIndex = args.indexOf('--kill-buffer');
  if (killIndex !== -1) {
    killBuffer = args[killIndex + 1];
  }

  // Parse insert text
  const insertIndex = args.indexOf('--insert');
  if (insertIndex !== -1) {
    insertText = args[insertIndex + 1];
  }

  // Parse script file
  const scriptIndex = args.indexOf('--script');
  if (scriptIndex !== -1) {
    scriptFile = args[scriptIndex + 1];
  }

  // Parse --key
  const keyIndex = args.indexOf('--key');
  if (keyIndex !== -1) {
    keyArg = args[keyIndex + 1];
  }

  // Parse --keys
  const keysIndex = args.indexOf('--keys');
  if (keysIndex !== -1) {
    keysArg = args[keysIndex + 1];
  }

  // Parse --command
  const commandIndex = args.indexOf('--command');
  if (commandIndex !== -1) {
    commandArg = args[commandIndex + 1];
  }

  // Parse --frame
  const frameIndex = args.indexOf('--frame');
  if (frameIndex !== -1) {
    frameTarget = args[frameIndex + 1];
  }

  // Parse --since-request
  const sinceIndex = args.indexOf('--since-request');
  if (sinceIndex !== -1) {
    const val = args[sinceIndex + 1];
    sinceRequestId = val && !val.startsWith('-') ? (Number(val) || val) : undefined;
  }

  // Get non-option arguments (filenames)
  const filenames = args.filter(arg =>
    !arg.startsWith('-') &&
    arg !== evalCode &&
    arg !== killBuffer &&
    arg !== insertText &&
    arg !== scriptFile &&
    arg !== socketPath &&
    arg !== keyArg &&
    arg !== keysArg &&
    arg !== commandArg &&
    arg !== frameTarget
  );

  // Handle TUI mode by spawning the TUI client process
  if (tuiMode) {
    const { spawn } = require('child_process');
    const path = require('path');
    const tuiClientPath = path.resolve(__dirname, '..', 'src', 'client', 'tui-client.ts');
    const tuiArgs = [];
    if (socketPath) {
      tuiArgs.push('-s', socketPath);
    }
    const child = spawn('bun', [tuiClientPath, ...tuiArgs], {
      stdio: 'inherit',
      env: process.env
    });
    child.on('exit', (code: number) => process.exit(code));
    return;
  }

  // Special handling for --stop - send shutdown RPC
  if (stopDaemon) {
    const stopClient = new TmaxClient(socketPath);
    try {
      await stopClient.connect();
      await stopClient.sendRequest('shutdown', {});
      stopClient.close();
      console.log('Daemon stopped');
      process.exit(0);
    } catch (error) {
      console.error('Daemon not running');
      process.exit(1);
    }
  }

  // Special handling for ping - don't require server connection
  if (ping) {
    // Try to connect to test if server is running
    const client = new TmaxClient(socketPath);
    try {
      await client.connect();
      const isRunning = await client.ping();
      client.close();
      if (isRunning) {
        console.log(JSON.stringify({ status: 'running', server: 'tmax' }));
      }
      process.exit(isRunning ? 0 : 1);
    } catch (error) {
      // Server not running
      console.error('tmax server not running');
      process.exit(1);
    }
  }

  // Create client
  const client = new TmaxClient(socketPath);

  try {
    await client.connect();
  } catch (error) {
    console.error('Error connecting to tmax server:', error.message);
    console.error('Make sure the server is running with: tmax --daemon');
    process.exit(1);
  }

  // Handle different commands
  if (serverInfo || status) {
    const info = await client.sendRequest('status', {});
    if (jsonOutput || serverInfo) {
      console.log(JSON.stringify(info, null, jsonOutput ? 0 : 2));
    } else {
      printStatus(info);
    }
  } else if (clients) {
    const result = await client.sendRequest('clients', {});
    if (jsonOutput) {
      console.log(JSON.stringify(result));
    } else {
      printClients(result);
    }
  } else if (frames) {
    const result = await client.sendRequest('frames', {});
    if (jsonOutput) {
      console.log(JSON.stringify(result));
    } else {
      printFrames(result);
    }
  } else if (showMessages) {
    const result = await client.query('messages');
    if (result && result.messages) {
      result.messages.forEach((msg: string) => console.log(msg));
    }
  } else if (listBuffers) {
    const buffers = await client.executeCommand('list-buffers');
    // Format output similar to how a real editor might show buffer list
    if (Array.isArray(buffers)) {
      buffers.forEach(buffer => console.log(buffer));
    } else {
      console.log(buffers);
    }
  } else if (killBuffer) {
    const result = await client.executeCommand('kill-buffer', { bufferName: killBuffer });
    if (result.success) {
      console.log(`Buffer ${killBuffer} killed`);
      process.exit(0);
    } else {
      console.error(result.error);
      process.exit(1);
    }
  } else if (insertText) {
    // Use the insert method to add text to the buffer
    const result = await client.sendRequest('insert', { text: insertText });
    console.log(result);
  } else if (insertStdin) {
    // Read from stdin and insert
    const stdin = await readStdin();
    const result = await client.sendRequest('insert', { text: stdin });
    console.log(result);
  } else if (scriptFile) {
    // Read the script file and evaluate it
    const fs = require('fs');
    const scriptContent = fs.readFileSync(scriptFile, 'utf8');
    const result = await client.eval(scriptContent);
    console.log(result);
  } else if (keyArg) {
    // Send a single keypress to the active frame
    const params: any = { key: keyArg };
    if (frameTarget) params.frameId = frameTarget;
    try {
      const result = await client.sendRequest('keypress', params);
      if (jsonOutput) {
        console.log(JSON.stringify(result));
      } else if (result) {
        console.log(typeof result === 'object' ? JSON.stringify(result) : result);
      }
    } catch (error: any) {
      const errData = error instanceof Error ? error.message : String(error);
      if (jsonOutput) {
        console.log(JSON.stringify({ ok: false, error: errData }));
      } else {
        console.error(errData);
      }
      process.exit(1);
    }
  } else if (keysArg) {
    // Replay a key sequence on the active frame
    // Parse <Key> notation and individual characters
    const keys = parseKeySequence(keysArg);
    for (const key of keys) {
      const params: any = { key };
      if (frameTarget) params.frameId = frameTarget;
      try {
        await client.sendRequest('keypress', params);
      } catch (error: any) {
        const errData = error instanceof Error ? error.message : String(error);
        if (jsonOutput) {
          console.log(JSON.stringify({ ok: false, key, error: errData }));
        } else {
          console.error(`Error on key '${key}': ${errData}`);
        }
        process.exit(1);
      }
    }
    if (jsonOutput) {
      console.log(JSON.stringify({ ok: true, operation: 'keys', keys }));
    } else {
      console.log(`Sent ${keys.length} keys`);
    }
  } else if (commandArg) {
    // Execute an editor command by name
    const params: any = { command: commandArg };
    if (frameTarget) params.frameId = frameTarget;
    try {
      const result = await client.sendRequest('command', params);
      if (jsonOutput) {
        console.log(JSON.stringify({ ok: true, result }));
      } else if (result !== undefined && result !== null) {
        console.log(typeof result === 'object' ? JSON.stringify(result) : result);
      }
    } catch (error: any) {
      const errData = error instanceof Error ? error.message : String(error);
      if (jsonOutput) {
        console.log(JSON.stringify({ ok: false, error: errData }));
      } else {
        console.error(errData);
      }
      process.exit(1);
    }
  } else if (showDiagnostics) {
    // Show recent diagnostics from the daemon
    const info = await client.sendRequest('status', {});
    let errors = info?.recentErrors ?? [];
    if (sinceRequestId !== undefined) {
      errors = errors.filter((e: any) => e.requestId === sinceRequestId);
    }
    if (jsonOutput) {
      console.log(JSON.stringify(errors));
    } else {
      if (errors.length === 0) {
        console.log('No recent diagnostics.');
      } else {
        for (const err of errors) {
          if (err.diagnostic) {
            console.log(`[${err.diagnostic.code}] ${err.message}`);
          } else {
            console.log(err.message);
          }
        }
      }
    }
  } else if (showLastError) {
    // Get last error from T-Lisp interpreter
    try {
      const result = await client.eval('(tlisp-last-error)');
      if (jsonOutput) {
        console.log(JSON.stringify(result));
      } else if (result && typeof result === 'string' && result !== '') {
        console.log(result);
      } else {
        console.log('No recent error.');
      }
    } catch {
      console.log('No recent error.');
    }
  } else if (showBacktrace) {
    // Get backtrace from T-Lisp interpreter
    try {
      const result = await client.eval('(tlisp-backtrace)');
      if (jsonOutput) {
        console.log(JSON.stringify(result));
      } else if (Array.isArray(result)) {
        for (const frame of result) {
          console.log(frame);
        }
      } else {
        console.log('No backtrace available.');
      }
    } catch {
      console.log('No backtrace available.');
    }
  } else if (evalCode) {
    const result = await client.eval(evalCode);
    if (result !== undefined) {
      console.log(typeof result === 'object' ? JSON.stringify(result) : result);
    }
  } else if (filenames.length > 0) {
    // Open files
    for (const filename of filenames) {
      await client.openFile(filename, { wait: !noWait });
    }
    // Exit with success code after opening files
    process.exit(0);
  } else {
    // No command specified, show help
    console.error('No command specified. Use --help for usage information.');
    process.exit(1);
  }

  client.close();
}

/**
 * Read from stdin
 */
async function readStdin(): Promise<string> {
  return new Promise((resolve) => {
    let data = '';
    process.stdin.setEncoding('utf8');

    process.stdin.on('readable', () => {
      let chunk;
      while ((chunk = process.stdin.read()) !== null) {
        data += chunk;
      }
    });

    process.stdin.on('end', () => {
      resolve(data);
    });
  });
}

function printStatus(info: any): void {
  console.log(`tmax ${info.status ?? 'unknown'}`);
  console.log(`socket: ${info.socketPath ?? '(unknown)'}`);
  console.log(`uptime: ${Math.floor((info.uptimeMs ?? 0) / 1000)}s`);
  console.log(`clients: ${info.clientCount ?? 0}`);
  console.log(`frames: ${info.frameCount ?? 0}`);
  if (info.editor) {
    console.log(`mode: ${info.editor.mode}`);
    console.log(`buffer: ${info.editor.bufferName ?? info.editor.currentFilename ?? '(none)'}`);
  }
  if (Array.isArray(info.recentErrors) && info.recentErrors.length > 0) {
    console.log(`recent errors: ${info.recentErrors.length}`);
  }
}

function printClients(clients: any[]): void {
  if (!Array.isArray(clients) || clients.length === 0) {
    console.log('No connected clients');
    return;
  }
  clients.forEach((client) => {
    console.log(`${client.id} ${client.clientType} requests=${client.requestCount} frame=${client.frameId ?? '-'}`);
  });
}

function printFrames(frames: any[]): void {
  if (!Array.isArray(frames) || frames.length === 0) {
    console.log('No connected frames');
    return;
  }
  frames.forEach((frame) => {
    const ready = frame.ready ? 'ready' : 'not-ready';
    console.log(`${frame.id} ${frame.clientType} ${ready} renders=${frame.renderCount} mode=${frame.mode}`);
  });
}

// Run the main function
main().catch(error => {
  console.error('Fatal error:', error);
  process.exit(1);
});
