(defmodule editor/indent/python
  (export)

;; python.tlisp — Python indent rules
;; Increase indent after colon at line end
;; Decrease for return/break/pass/else/elif at line start
(indent-set-rules
  '(":$" "else:$" "elif .+:$" "except$" "finally$" "class .+:$" "def .+:$")
  '("^\\s*return" "^\\s*break" "^\\s*pass" "^\\s*else:" "^\\s*elif" "^\\s*except" "^\\s*finally"))
)
