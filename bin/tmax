#!/usr/bin/env bash
# tmax — unified editor CLI (emacs-style daemon/client)
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH")"
fi

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DAEMON="$PROJECT_DIR/src/server/server.ts"
TUI="$PROJECT_DIR/src/client/tui-client.ts"
CLIENT="$PROJECT_DIR/bin/tmaxclient"
TMAX_UID="$(id -u)"
SOCKET="${TMAX_SOCKET:-/tmp/tmax-${TMAX_UID}/server}"

usage() {
  cat <<EOF
Usage: tmax [options] [file]

Options:
  --daemon       Start daemon only (no TUI frame)
  -w, --workspace NAME  Open/connect to workspace NAME
  -w new:NAME    Create workspace NAME, then connect to it
  --workspaces   List workspaces
  --workspace-kill NAME  Delete a workspace
  -e EXPR        Evaluate T-Lisp expression (like emacsclient -e)
  --stop         Stop the running daemon
  --capture      Capture current frame as ANSI (colors preserved)
  --capture-html Capture current frame as standalone HTML
  --test         Run the trt native test suite (exit 0 pass / 1 fail / 2 no-tests)
  --json         With --test: emit JSON results (parseable by jq)
  -t             Open a new terminal frame
  -h, --help     Show this help message

Examples:
  tmax                  Start daemon + open TUI frame
  tmax file.txt         Start daemon + open TUI with file
  tmax --daemon         Start daemon only
  tmax -e '(buffer-text)'  Evaluate T-Lisp
  tmax --capture        Dump current frame with colors
  tmax --capture-html > /tmp/frame.html && open /tmp/frame.html
  tmax --stop           Stop daemon
EOF
  exit 0
}

# Check if daemon is alive
is_running() {
  "$CLIENT" -s "$SOCKET" --ping 2>/dev/null
}

# Wait for daemon to be ready
wait_for_daemon() {
  local attempts=0
  while [ $attempts -lt 25 ]; do
    if is_running >/dev/null 2>&1; then
      return 0
    fi
    # If a lock exists and the process is alive, another launcher is starting it
    if [ -f "${SOCKET}.lock" ]; then
      local lock_pid
      lock_pid=$(python3 -c "import json,sys; print(json.load(open('${SOCKET}.lock'))['pid'])" 2>/dev/null || echo "")
      if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
        : # wait for the other launcher's daemon to come up
      else
        # stale lock from dead process — remove it so we can retry
        rm -f "${SOCKET}.lock" 2>/dev/null || true
      fi
    fi
    sleep 0.2
    attempts=$((attempts + 1))
  done
  echo "Error: Daemon did not start" >&2
  return 1
}

# Start daemon if not running
ensure_daemon() {
  if is_running >/dev/null 2>&1; then
    return 0
  fi

  # Capture daemon startup output for diagnostics on failure
  local daemon_log
  daemon_log=$(mktemp /tmp/tmax-daemon-start.XXXXXX.log)

  # Start daemon in background (from project root so relative paths resolve)
  (cd "$PROJECT_DIR" && TMAX_SOCKET="$SOCKET" bun "$DAEMON" >"$daemon_log" 2>&1) &
  local daemon_pid=$!

  # Wait for socket
  if wait_for_daemon; then
    rm -f "$daemon_log" 2>/dev/null || true
    return 0
  fi

  # Show recent daemon output to help diagnose the failure
  echo "Error: Failed to start daemon (pid $daemon_pid)" >&2
  if [ -s "$daemon_log" ]; then
    echo "--- daemon log ---" >&2
    tail -20 "$daemon_log" >&2
    echo "--- end ---" >&2
  fi
  rm -f "$daemon_log" 2>/dev/null || true
  return 1
}

# Parse arguments
DAEMON_ONLY=false
EVAL_EXPR=""
STOP=false
CAPTURE=""
WORKSPACE=""
WORKSPACES=false
WORKSPACE_KILL=""
TEST_MODE=false
TEST_JSON=false
TEST_TARGET=""
FILES=()

for arg in "$@"; do
  case "$arg" in
    --daemon)       DAEMON_ONLY=true ;;
    -w)             shift_mode=workspace ;;
    --workspace)    shift_mode=workspace ;;
    --workspaces)   WORKSPACES=true ;;
    --workspace-kill) shift_mode=workspace_kill ;;
    -e)             shift_mode=eval ;;
    --stop)         STOP=true ;;
    --capture)      CAPTURE=ansi ;;
    --capture-html) CAPTURE=html ;;
    --test)         TEST_MODE=true ;;
    --json)         TEST_JSON=true ;;
    -t)             ;; # -t is default behavior (open terminal frame)
    -h|--help)      usage ;;
    *)
      if [ "${shift_mode:-}" = "eval" ]; then
        EVAL_EXPR="$arg"
        shift_mode=""
      elif [ "${shift_mode:-}" = "workspace" ]; then
        WORKSPACE="$arg"
        shift_mode=""
      elif [ "${shift_mode:-}" = "workspace_kill" ]; then
        WORKSPACE_KILL="$arg"
        shift_mode=""
      elif [ "$TEST_MODE" = true ] && [ -z "$TEST_TARGET" ]; then
        TEST_TARGET="$arg"
      else
        FILES+=("$arg")
      fi
      ;;
  esac
done

# I6: error on flags that expect an argument but didn't get one
if [ "${shift_mode:-}" = "workspace" ]; then
  echo "Error: -w requires a workspace name argument" >&2
  exit 1
elif [ "${shift_mode:-}" = "workspace_kill" ]; then
  echo "Error: --workspace-kill requires a workspace name argument" >&2
  exit 1
elif [ "${shift_mode:-}" = "eval" ]; then
  echo "Error: -e requires an expression argument" >&2
  exit 1
fi

# Handle --stop
if [ "$STOP" = true ]; then
  if is_running >/dev/null 2>&1; then
    "$CLIENT" -s "$SOCKET" --stop 2>/dev/null
    # Verify it actually stopped
    sleep 1
    if is_running >/dev/null 2>&1; then
      echo "Warning: daemon did not stop gracefully, sending SIGTERM" >&2
      # Find PID from lsof on the socket
      DAEMON_PID=$(lsof -t -U "$SOCKET" 2>/dev/null | head -1 || true)
      if [ -n "$DAEMON_PID" ]; then
        kill -TERM "$DAEMON_PID" 2>/dev/null || true
        sleep 1
      fi
    fi
    # Clean up socket and lock
    rm -f "$SOCKET" "${SOCKET}.lock" 2>/dev/null || true
    echo "Daemon stopped"
  else
    echo "Daemon not running"
  fi
  exit 0
fi

# Handle --test (trt native test runner). Evals (trt-run [target]) on the daemon, prints results
# (JSON if --json), and exits with the runner's code: 0 all-pass / 1 any-fail / 2 no-tests or error.
if [ "$TEST_MODE" = true ]; then
  ensure_daemon
  if [ -n "$TEST_TARGET" ]; then
    LOAD_EXPR="(trt-load-file \"$TEST_TARGET\")"
  else
    LOAD_EXPR='(trt-load-directory "test/tlisp/")'
  fi
  # Run once; then the exit-code eval reads the same result store (no re-run needed).
  "$CLIENT" -s "$SOCKET" --eval "(progn $LOAD_EXPR (trt-run-all))" >/dev/null 2>&1
  if [ "$TEST_JSON" = true ]; then
    REPORT="$("$CLIENT" -s "$SOCKET" --eval '(trt-results-json)' 2>/dev/null)"
    # The client prints the value; for JSON we want the raw payload.
    echo "$REPORT"
  else
    REPORT="$("$CLIENT" -s "$SOCKET" --eval '(trt-print-report)' 2>/dev/null)"
    # Strip the surrounding quotes the printer adds to string values.
    echo "$REPORT" | sed -e 's/^"//' -e 's/"$//'
  fi
  EXIT_CODE="$("$CLIENT" -s "$SOCKET" --eval '(trt-exit-code-ts)' 2>/dev/null | tr -dc '0-9')"
  case "$EXIT_CODE" in
    0|1|2) exit "$EXIT_CODE" ;;
    *) exit 2 ;;
  esac
fi

# Handle -e (eval only, no TUI)
if [ -n "$EVAL_EXPR" ]; then
  ensure_daemon
  if [ -n "$WORKSPACE" ]; then
    exec "$CLIENT" --workspace "$WORKSPACE" --eval "$EVAL_EXPR"
  else
    exec "$CLIENT" --eval "$EVAL_EXPR"
  fi
fi

# Handle workspace management commands
if [ "$WORKSPACES" = true ]; then
  ensure_daemon
  exec "$CLIENT" -s "$SOCKET" --workspaces
fi

if [ -n "$WORKSPACE_KILL" ]; then
  ensure_daemon
  exec "$CLIENT" -s "$SOCKET" --workspace-kill "$WORKSPACE_KILL"
fi

# Handle --capture / --capture-html
if [ -n "$CAPTURE" ]; then
  ensure_daemon
  if [ "$CAPTURE" = "html" ]; then
    exec "$CLIENT" -s "$SOCKET" --capture-html
  else
    exec "$CLIENT" -s "$SOCKET" --capture
  fi
fi

# Handle --daemon only
if [ "$DAEMON_ONLY" = true ]; then
  if is_running >/dev/null 2>&1; then
    echo "Daemon already running"
    exit 0
  fi
  cd "$PROJECT_DIR" && TMAX_SOCKET="$SOCKET" exec bun "$DAEMON"
fi

# Default: single-process editor with embedded server
# (like running emacs — the editor IS the process, socket is in-process)
if [ -n "$WORKSPACE" ]; then
  ensure_daemon
  if [[ "$WORKSPACE" == new:* ]]; then
    NEW_WORKSPACE="${WORKSPACE#new:}"
    if ! "$CLIENT" -s "$SOCKET" --workspace-new "$NEW_WORKSPACE" >/dev/null 2>&1; then
      echo "Error: Failed to create workspace '$NEW_WORKSPACE'" >&2
      exit 1
    fi
    WORKSPACE="$NEW_WORKSPACE"
  fi
  exec "$CLIENT" -s "$SOCKET" --workspace "$WORKSPACE" --tui
fi

# C6: try last-workspace persistence when no -w flag given
LAST_WS_FILE="$HOME/.config/tmax/last-workspace"
if [ -z "$WORKSPACE" ] && [ -f "$LAST_WS_FILE" ] && is_running >/dev/null 2>&1; then
  LAST_WS=$(cat "$LAST_WS_FILE" 2>/dev/null)
  if [ -n "$LAST_WS" ]; then
    exec "$CLIENT" -s "$SOCKET" --workspace "$LAST_WS" --tui
  fi
fi

cd "$PROJECT_DIR" && exec bun src/main.ts "${FILES[@]}"
