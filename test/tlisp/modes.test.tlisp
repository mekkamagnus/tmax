;; Native T-Lisp checks for SPEC-003 mode behavior.
;; Uses the trt should-* assertion API (SPEC-049 self-hosted framework).

(deftest mode-features-loaded ()
  (should-be-truthy (featurep "python-mode"))
  (should-be-truthy (featurep "line-numbers-mode")))

(deftest generated-minor-mode-command-enable-disable ()
  (line-numbers-mode t)
  (should-be-truthy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode t)
  (should-be-truthy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode nil)
  (should-be-falsy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode)
  (should-be-truthy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode 0)
  (should-be-falsy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode 1)
  (should-be-truthy (minor-mode-active-p "line-numbers"))
  (line-numbers-mode -1)
  (should-be-falsy (minor-mode-active-p "line-numbers")))

(deftest callable-hook-form-runs ()
  (defvar hook-ran nil)
  (add-hook "native-mode-test-hook" (lambda () (set! hook-ran t)))
  (run-hooks "native-mode-test-hook")
  (should-be-truthy hook-ran))
