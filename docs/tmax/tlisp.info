5 Special Forms
***************

 -- Special: Form quote expr
     Return EXPR without evaluating it.
          (quote x)    ; => x
          '(1 2 3)     ; => (1 2 3)

 -- Special: Form if condition then-expr else-expr
     Evaluate CONDITION.  If truthy, evaluate and return THEN-EXPR;
     otherwise evaluate and return ELSE-EXPR.
          (if (> 3 2) "yes" "no")  ; => "yes"

 -- Special: Form let bindings body...
     Create local variable bindings.  BINDINGS is a list of ‘(name
     value)’ pairs.
          (let ((x 10) (y 20))
            (+ x y))  ; => 30

 -- Special: Form lambda params docstring? body...
     Create an anonymous function.  Optional DOCSTRING after PARAMS.
          (lambda (x) (* x x))
          (funcall (lambda (x y) (+ x y)) 3 4)  ; => 7

 -- Special: Form defun name params docstring? body...
     Define a named function in the current environment.
          (defun square (x)
            (* x x))
          (square 5)  ; => 25

 -- Special: Form defmacro name params body...
     Define a macro.  The body is evaluated at expansion time, not call
     time.
          (defmacro when (condition . body)
            `(if ,condition (progn ,@body)))

 -- Special: Form progn expr...
     Evaluate each expression in sequence.  Return the value of the
     last.
          (progn
            (buffer-insert "Hello")
            (cursor-move 0 0))

 -- Special: Form cond clause...
     Multi-way conditional.  Each clause is ‘(condition expr)’.  Use ‘t’
     as condition for else.
          (cond
            ((< x 0) "negative")
            ((= x 0) "zero")
            (t "positive"))

 -- Special: Form defvar name value
     Define a variable in the global environment.
          (defvar tab-width 4)

 -- Special: Form defmodule name forms...
     Define a module with an isolated environment.  A module body may
     include ‘(export ...)’ to declare its public API and
     ‘require-module’ forms to import dependencies.
          (defmodule std/example
            (export double)
            (defun double (n) (* n 2)))

 -- Special: Form require-module module [:as alias|:import symbols]
     Load MODULE and register an import in the current scope.  With
     ‘:as’, exported names are referenced as ‘alias/name’.  With
     ‘:import’, selected exported names are imported unqualified.
          (require-module std/strings :as s)
          (s/join "," (list "a" "b"))

 -- Special: Form set! name value
     Set an existing variable's value.
          (set! tab-width 2)


File: tlisp.info,  Node: Quasiquote System,  Next: Standard Library,  Prev: Special Forms,  Up: Top

6 Quasiquote System
*******************

 -- Special: Form quasiquote expr `
     Template quotation -- like ‘quote’ but allows selective evaluation.
          `(a b c)              ; => (a b c)

 -- Special: Form unquote expr ,
     Evaluate EXPR within a quasiquote.
          (let ((x 42))
            `(the answer is ,x))  ; => (the answer is 42)

 -- Special: Form unquote-splicing expr ,@
     Splice list elements into the enclosing quasiquote.
          (let ((nums '(1 2 3)))
            `(before ,@nums after))  ; => (before 1 2 3 after)


