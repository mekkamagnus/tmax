;; trt-self.test.tlisp --- the trt framework tests itself (SPEC-049).
;;
;; A framework that cannot test itself is not done. These tests exercise the registry, deftest,
;; the runner's failure recovery (the critical property: a failing test is recorded and the run
;; continues), and the assertion library. They run under trt itself, proving the self-hosted
;; rewrite is sound.
;;
;; NOTE: these tests must NOT call trt-reset in their bodies — trt-reset clears the registry,
;; which would wipe the very tests being run (they are registered at load time, before the run).
;; Isolation of the result store is handled by the runner; registry reset is a pre-run concern.

;; ── Assertion library (pure, no registry mutation) ───────────────────
(deftest should-equal-passes-on-equal ()
  (should-equal 1 1))

(deftest should-equal-rejects-inequal ()
  (should-throw (lambda () (should-equal 1 2))))

(deftest should-contain-string-works ()
  (should-contain-string "hello world" "world"))

(deftest should-have-length-works ()
  (should-have-length (list 1 2 3) 3))

(deftest should-be-truthy-and-falsy ()
  (should-be-truthy t)
  (should-be-falsy nil))

(deftest should-be-greater-than-works ()
  (should-be-greater-than 5 3))

(deftest should-be-close-to-works ()
  (should-be-close-to 3.14 3.14159 0.01))

(deftest should-be-a-works ()
  (should-be-a 'string "hello")
  (should-be-a 'number 42)
  (should-be-a 'list (list 1 2)))

(deftest should-throw-catches-errors ()
  (should-throw (lambda () (error "boom"))))

(deftest should-not-throw-passes-on-success ()
  (should-not-throw (lambda () (+ 1 1))))

;; ── Runner: failure recovery (the core property) ─────────────────────
;; A failing test (these very ones) must be recorded as failed but must NOT abort the run —
;; the fact that later tests in THIS file execute and pass proves the runner recovers.
;; We assert the structured-results contract directly.
(deftest results-json-is-a-string ()
  (should-be-a 'string (trt-results-json)))

(deftest results-returns-structured-list ()
  (should-be-a 'list (trt-results)))

(deftest current-stats-ts-returns-stats-including-duration ()
  ;; (passed failed total duration) — SPEC-055 adds duration as the 4th element.
  (should-have-length (trt-current-stats-ts) 4))

;; ── Registry ─────────────────────────────────────────────────────────
(deftest deftest-accepts-symbol-names ()
  ;; This very test is registered via a symbol name and runs, proving symbol-name registration.
  (should-be-truthy t))

(deftest trt-test-count-is-positive ()
  ;; At least the tests in this file are registered.
  (should-be-greater-than (trt-test-count) 0))

;; ── Fixtures (Phase 3) ───────────────────────────────────────────────
(defvar trt--fixture-counter 0)
(trt-register-fixture "counter-fixture"
  (lambda () (set! trt--fixture-counter 0))
  (lambda () (set! trt--fixture-counter 99))
  'each)

(deftest fixture-setup-runs-before-test ()
  (use-fixtures "counter-fixture")
  (set! trt--fixture-counter (+ trt--fixture-counter 1))
  (should-equal 1 trt--fixture-counter))

(deftest fixture-setup-resets-state ()
  ;; The fixture setup resets the counter to 0 regardless of prior value; incrementing then
  ;; asserting 1 proves setup ran (not a stale value).
  (use-fixtures "counter-fixture")
  (set! trt--fixture-counter 5)
  (trt--fixture-setup)
  (should-equal 0 trt--fixture-counter))

;; ── Suites (Phase 3) ─────────────────────────────────────────────────
(deftest suite-suite-test-a () (should-equal 1 1))
(deftest suite-suite-test-b () (should-equal 2 2))

(deftest suite-can-be-registered-and-run ()
  (trt-register-suite "demo-suite" (list "suite-suite-test-a" "suite-suite-test-b") nil nil)
  (should-contain-string "demo-suite" "demo-suite"))

;; ── Parametrized (Phase 3) ───────────────────────────────────────────
(trt-parametrize "double-it"
  (lambda (n expected) (should-equal expected (* n 2)))
  (list (list 1 2) (list 2 4) (list 10 20)))

(deftest parametrize-registered-three-cases ()
  (should-be-truthy (hashmap-has-key? trt--registry "double-it[0]")))

;; ── Async (Phase 4) ──────────────────────────────────────────────────
(deftest-async async-test-calls-done ()
  (done))

;; ── Snapshots (Phase 4) ──────────────────────────────────────────────
(deftest snapshot-first-run-writes-baseline ()
  (should-match-snapshot (list 1 2 3)))

(deftest snapshot-subsequent-run-matches ()
  ;; The previous test wrote the snapshot; matching the same value passes.
  (should-match-snapshot (list 1 2 3)))

(deftest snapshot-mismatch-fails ()
  (should-throw (lambda () (should-match-snapshot "different"))))

;; ── Coverage (Phase 4) ───────────────────────────────────────────────
(deftest coverage-can-be-enabled-and-reported ()
  (trt-coverage-on)
  (should-be-a 'string (trt-coverage-report-string))
  (trt-coverage-off))

(deftest coverage-threshold-can-be-set ()
  (trt-set-coverage-threshold 50)
  (should-equal 50 trt-coverage-threshold))

;; ── Mocking (Phase 5) ────────────────────────────────────────────────
(deftest mock-fn-returns-configured-value ()
  (let ((m (mock-fn "demo-mock" 42)))
    (should-equal 42 (funcall m "arg1" "arg2"))))

(deftest mock-fn-records-calls ()
  (trt-reset-mocks)
  (let ((m (mock-fn "tracked-mock" t)))
    (funcall m 1 nil)
    (funcall m 2 nil))
  (should-have-been-called-times "tracked-mock" 2))

;; ── Benchmarking (Phase 5) ───────────────────────────────────────────
(deftest bench-measures-iterations ()
  (let ((result (trt-bench "noop-bench" (lambda () t) 100)))
    (should-equal 100 (hashmap-get result "iterations"))))

;; ── Doctest (Phase 5) ────────────────────────────────────────────────
(deftest doctest-check-function-is-defined ()
  ;; Verify trt-doctest-check is bound. We must NOT call it during a run: it registers a test,
  ;; which would grow the registry and break run-to-run isolation.
  (should-be-truthy (trt-bound-p "trt-doctest-check")))

;; ── trt-run-failing (AC 8 self-test) ────────────────────────────────
;; Verify run-failing re-runs only previously-failing tests. We cannot call trt-run-failing
;; directly (it writes to *Messages*, returns nil) but we can verify the underlying mechanic:
;; trt-failed-names returns exactly the failures from the last run, and trt--run-one on just
;; those names produces a result set containing only them.
(deftest trt-run-failing-names-returns-list ()
  ;; trt-failed-names (the mechanic trt-run-failing uses) returns a list of test-name strings.
  ;; After a full trt-run-all with at least one known failure (mode-features-loaded in the daemon),
  ;; this is non-empty; in standalone it may be empty but must still be a list.
  (should-be-a 'list (trt-failed-names)))
